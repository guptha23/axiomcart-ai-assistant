# AxiomCart AI Assistant - Environment Variables
# Copy this file to .env and fill in your values

OPENAI_API_KEY=sk-your-openai-api-key-here

# Model to use for all LLM calls (orchestrator, agents, synthesizer)
# gpt-3.5-turbo  → affordable for development / testing
# gpt-4o-mini    → production-grade reasoning (recommended for class demos)
LLM_MODEL=gpt-4o-mini

# Embedding model for RAG (leave as default unless you have a specific reason)
EMBEDDINGS_MODEL=text-embedding-3-small

